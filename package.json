{
  "name": "piagent-vscode",
  "displayName": "PiAgent - AI Coding Agent",
  "description": "AI coding agent for VSCode Chat. Read, write, edit files and run bash commands using Claude, GPT-4, Gemini, and 10+ LLM providers. No permission prompts - tools execute directly. Uses the same shared configuration as the pi CLI.",
  "version": "0.1.6",
  "publisher": "brijbyte",
  "author": {
    "name": "BrijByte",
    "url": "https://github.com/brijbyte"
  },
  "license": "MIT",
  "homepage": "https://github.com/brijbyte/piagent-vscode#readme",
  "bugs": {
    "url": "https://github.com/brijbyte/piagent-vscode/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brijbyte/piagent-vscode"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "ai-agent",
    "coding-agent",
    "coding-assistant",
    "chat-participant",
    "llm",
    "claude",
    "anthropic",
    "openai",
    "gpt-4",
    "gemini",
    "bedrock",
    "deepseek",
    "groq",
    "mistral",
    "openrouter",
    "copilot-alternative",
    "code-generation",
    "developer-tools",
    "file-editing",
    "bash",
    "terminal",
    "multi-provider",
    "session-management"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "chatParticipants": [
      {
        "id": "piagent.agent",
        "fullName": "PiAgent",
        "name": "piagent",
        "description": "AI coding agent with read, bash, edit, write tools",
        "isSticky": true,
        "commands": [
          {
            "name": "new",
            "description": "Start a new session"
          },
          {
            "name": "resume",
            "description": "Resume a previous session"
          },
          {
            "name": "model",
            "description": "Select a different model"
          },
          {
            "name": "compact",
            "description": "Compact the session context"
          },
          {
            "name": "session",
            "description": "Show session info and stats"
          },
          {
            "name": "login",
            "description": "Login with an OAuth provider"
          },
          {
            "name": "logout",
            "description": "Logout from an OAuth provider"
          },
          {
            "name": "clear",
            "description": "Clear chat history but keep session"
          },
          {
            "name": "copy",
            "description": "Copy last response to clipboard"
          },
          {
            "name": "retry",
            "description": "Retry the last prompt"
          },
          {
            "name": "help",
            "description": "Show available commands"
          },
          {
            "name": "settings",
            "description": "Open extension settings"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "piagent.newSession",
        "title": "PiAgent: New Session"
      },
      {
        "command": "piagent.resumeSession",
        "title": "PiAgent: Resume Session"
      },
      {
        "command": "piagent.selectModel",
        "title": "PiAgent: Select Model"
      },
      {
        "command": "piagent.login",
        "title": "PiAgent: Login"
      },
      {
        "command": "piagent.logout",
        "title": "PiAgent: Logout"
      },
      {
        "command": "piagent.explainCode",
        "title": "PiAgent: Explain Code"
      },
      {
        "command": "piagent.refactorCode",
        "title": "PiAgent: Refactor Code"
      },
      {
        "command": "piagent.writeTests",
        "title": "PiAgent: Write Tests"
      },
      {
        "command": "piagent.findBugs",
        "title": "PiAgent: Find Bugs"
      },
      {
        "command": "piagent.addDocs",
        "title": "PiAgent: Add Documentation"
      },
      {
        "command": "piagent.optimizeCode",
        "title": "PiAgent: Optimize Code"
      }
    ],
    "submenus": [
      {
        "id": "piagent.submenu",
        "label": "PiAgent"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "piagent.submenu",
          "group": "piagent",
          "when": "editorHasSelection"
        }
      ],
      "piagent.submenu": [
        {
          "command": "piagent.explainCode",
          "group": "1_understand"
        },
        {
          "command": "piagent.findBugs",
          "group": "1_understand"
        },
        {
          "command": "piagent.refactorCode",
          "group": "2_improve"
        },
        {
          "command": "piagent.optimizeCode",
          "group": "2_improve"
        },
        {
          "command": "piagent.addDocs",
          "group": "3_document"
        },
        {
          "command": "piagent.writeTests",
          "group": "3_document"
        }
      ]
    },
    "keybindings": [
      {
        "command": "piagent.selectModel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "PiAgent",
      "properties": {
        "piagent.statusBar.show": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "inputTokens",
              "outputTokens",
              "cacheRead",
              "cacheWrite",
              "cost",
              "contextUsage"
            ],
            "enumDescriptions": [
              "Input tokens sent to the model (↑)",
              "Output tokens received from the model (↓)",
              "Tokens read from prompt cache (R)",
              "Tokens written to prompt cache (W)",
              "Cumulative session cost in USD ($), shows (sub) for OAuth subscriptions",
              "Context window usage as percentage with auto-compaction indicator"
            ]
          },
          "default": [
            "inputTokens",
            "outputTokens",
            "cacheRead",
            "cacheWrite",
            "cost",
            "contextUsage"
          ],
          "markdownDescription": "Controls which token usage stats are shown in the status bar next to the model name. Remove items from the array to hide them.\n\nExample status bar: `$(robot) claude-opus-4-6 ↑141 / ↓26k / R7.8M / W99k / $5.159 (sub) / 49.7%/200k (auto)`\n\n| Value | Status bar | Description |\n|---|---|---|\n| `inputTokens` | `↑141` | Input tokens |\n| `outputTokens` | `↓26k` | Output tokens |\n| `cacheRead` | `R7.8M` | Cache read tokens |\n| `cacheWrite` | `W99k` | Cache write tokens |\n| `cost` | `$5.159 (sub)` | Session cost |\n| `contextUsage` | `49.7%/200k (auto)` | Context window usage |\n\nSet to an empty array `[]` to show only the model name.",
          "scope": "window"
        },
        "piagent.autoCompaction": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically compact the conversation context when approaching the model's token limit. When enabled, older messages are summarized to free up space while preserving recent context.",
          "scope": "window"
        },
        "piagent.autoRetry": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically retry failed API requests with exponential backoff. Helps handle transient network errors and rate limits.",
          "scope": "window"
        },
        "piagent.blockImages": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Block image attachments from being sent to the model. Useful for reducing token usage or when using models that don't support vision.",
          "scope": "window"
        },
        "piagent.thinkingLevel": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high"
          ],
          "default": "medium",
          "enumDescriptions": [
            "Disable extended thinking (fastest, cheapest)",
            "Minimal thinking budget",
            "Low thinking budget",
            "Medium thinking budget (default)",
            "High thinking budget (most thorough)"
          ],
          "markdownDescription": "Default thinking level for reasoning models (Claude with extended thinking, o1, etc.). Higher levels allow more thorough reasoning but use more tokens.",
          "scope": "window"
        },
        "piagent.quickActions": {
          "type": "object",
          "markdownDescription": "Configure quick actions available in the lightbulb menu and context menu when code is selected.",
          "additionalProperties": false,
          "properties": {
            "explainCode": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "prompt": {
                  "type": "string",
                  "default": "Explain this code clearly and concisely:"
                }
              },
              "default": {
                "enabled": true,
                "prompt": "Explain this code clearly and concisely:"
              }
            },
            "findBugs": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "prompt": {
                  "type": "string",
                  "default": "Analyze this code for potential bugs, edge cases, and issues:"
                }
              },
              "default": {
                "enabled": true,
                "prompt": "Analyze this code for potential bugs, edge cases, and issues:"
              }
            },
            "refactorCode": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "prompt": {
                  "type": "string",
                  "default": "Refactor this code to improve readability, performance, or maintainability:"
                }
              },
              "default": {
                "enabled": true,
                "prompt": "Refactor this code to improve readability, performance, or maintainability:"
              }
            },
            "optimizeCode": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "prompt": {
                  "type": "string",
                  "default": "Optimize this code for better performance:"
                }
              },
              "default": {
                "enabled": true,
                "prompt": "Optimize this code for better performance:"
              }
            },
            "addDocs": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "prompt": {
                  "type": "string",
                  "default": "Add clear documentation and comments to this code:"
                }
              },
              "default": {
                "enabled": true,
                "prompt": "Add clear documentation and comments to this code:"
              }
            },
            "writeTests": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "prompt": {
                  "type": "string",
                  "default": "Write comprehensive unit tests for this code:"
                }
              },
              "default": {
                "enabled": true,
                "prompt": "Write comprehensive unit tests for this code:"
              }
            }
          },
          "default": {
            "explainCode": {
              "enabled": true,
              "prompt": "Explain this code clearly and concisely:"
            },
            "findBugs": {
              "enabled": true,
              "prompt": "Analyze this code for potential bugs, edge cases, and issues:"
            },
            "refactorCode": {
              "enabled": true,
              "prompt": "Refactor this code to improve readability, performance, or maintainability:"
            },
            "optimizeCode": {
              "enabled": true,
              "prompt": "Optimize this code for better performance:"
            },
            "addDocs": {
              "enabled": true,
              "prompt": "Add clear documentation and comments to this code:"
            },
            "writeTests": {
              "enabled": true,
              "prompt": "Write comprehensive unit tests for this code:"
            }
          },
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "esbuild src/extension.mts --bundle --outfile=dist/extension.js --external:vscode --external:koffi --external:@mariozechner/clipboard --external:@mariozechner/pi-tui --external:cli-highlight --external:diff --external:extract-zip --external:marked --format=cjs --platform=node --inject:src/import-meta-polyfill.js --define:import.meta.url=importMetaUrl --minify",
    "build:watch": "npm run build -- --watch",
    "package": "vsce package --no-dependencies",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.55.1",
    "@mariozechner/pi-coding-agent": "^0.55.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
